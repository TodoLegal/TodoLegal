<% content_for :title, "#{@user.first_name} #{@user.last_name}" %>

<div class="min-h-screen bg-cream-50 p-8">
  <div class="max-w-2xl mx-auto">

    <div class="mb-6 flex items-center justify-between">
      <%= link_to "← Todos los usuarios", todolegal_ai_admin_users_path,
          class: "text-sm text-brand-400 hover:text-brand-500 transition-colors" %>
    </div>

    <div class="rounded-3xl border border-cream-200 bg-white px-8 py-8 shadow-sm">

      <%# Header %>
      <div class="flex items-start justify-between mb-6">
        <div>
          <h1 class="font-serif text-2xl font-semibold text-ink">
            <%= "#{@user.first_name} #{@user.last_name}".strip.presence || "Usuario sin nombre" %>
          </h1>
          <p class="text-sm text-brand-300 mt-0.5"><%= @user.email %></p>
        </div>
        <% if @user.todolegal_ai_status == 'active' %>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-green-50 px-3 py-1 text-xs font-medium text-green-700">
            <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>Activo
          </span>
        <% else %>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-50 px-3 py-1 text-xs font-medium text-amber-700">
            <span class="h-1.5 w-1.5 rounded-full bg-amber-400"></span>Pendiente invitación
          </span>
        <% end %>
        <% if @user.migrated_to_todolegal_ai? %>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-indigo-50 px-3 py-1 text-xs font-medium text-indigo-700 mt-1">
            <span class="h-1.5 w-1.5 rounded-full bg-indigo-400"></span>Migrado desde TodoLegal
          </span>
        <% end %>
      </div>

      <hr class="border-cream-200 mb-6">

      <%# Details %>
      <dl class="space-y-4 text-sm">
        <div class="flex gap-4">
          <dt class="w-36 text-brand-300 flex-shrink-0">Creado el</dt>
          <dd class="text-ink"><%= @user.created_at.strftime("%d de %B de %Y") %></dd>
        </div>
        <div class="flex gap-4">
          <dt class="w-36 text-brand-300 flex-shrink-0">Último acceso</dt>
          <dd class="text-ink">
            <%= @user.last_sign_in_at ? @user.last_sign_in_at.strftime("%d de %B de %Y, %H:%M") : "Nunca" %>
          </dd>
        </div>
        <div class="flex gap-4">
          <dt class="w-36 text-brand-300 flex-shrink-0">Inicios de sesión</dt>
          <dd class="text-ink"><%= @user.sign_in_count || 0 %></dd>
        </div>
      </dl>

      <% if @user.todolegal_ai_status == 'pending' %>
        <hr class="border-cream-200 my-6">
        <div class="rounded-2xl bg-amber-50 border border-amber-100 px-5 py-4">
          <p class="text-sm text-amber-800 mb-3">
            Este usuario aún no ha activado su cuenta. Puedes reenviar el correo de bienvenida.
          </p>
          <%= button_to "Reenviar invitación", resend_invite_todolegal_ai_admin_user_path(@user),
              method: :post,
              class: "rounded-xl bg-ink px-4 py-2 text-xs font-semibold text-cream-50 hover:bg-warmdark transition-colors cursor-pointer" %>
        </div>
      <% end %>

    </div>
  </div>
</div>
