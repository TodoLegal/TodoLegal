<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= yield(:subject) { "TodoLegal AI" } %></title>
  <style>
    body { margin: 0; padding: 0; background-color: #FAFAF7; font-family: 'Inter', system-ui, -apple-system, sans-serif; }
    .wrapper { max-width: 560px; margin: 40px auto; }
    .card { background: #ffffff; border: 1px solid #E8E4DA; border-radius: 20px; padding: 40px; }
    .logo { display: flex; align-items: center; gap: 10px; margin-bottom: 32px; }
    .logo-icon { width: 36px; height: 36px; background: #1A2B4A; border-radius: 8px; }
    .logo-text { font-size: 18px; font-weight: 600; color: #1A2B4A; letter-spacing: -0.3px; }
    h1 { font-size: 22px; font-weight: 700; color: #1A2B4A; margin: 0 0 8px 0; line-height: 1.3; }
    p { font-size: 14px; color: #64748B; line-height: 1.6; margin: 0 0 16px 0; }
    .cta-btn { display: inline-block; background: #1A2B4A; color: #FAFAF7; text-decoration: none; padding: 12px 28px; border-radius: 14px; font-size: 14px; font-weight: 600; margin: 24px 0; }
    .cta-btn:hover { background: #1A1815; }
    .divider { border: none; border-top: 1px solid #E8E4DA; margin: 24px 0; }
    .footer { font-size: 12px; color: #94A3B8; line-height: 1.5; margin-top: 24px; text-align: center; }
    .url-fallback { word-break: break-all; color: #475569; font-size: 12px; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="card">
      <div class="logo">
        <div class="logo-icon"></div>
        <span class="logo-text">TodoLegal AI</span>
      </div>
      <%= yield %>
    </div>
    <p class="footer">
      &copy; <%= Time.current.year %> TodoLegal. Todos los derechos reservados.<br>
      Este correo fue enviado desde una dirección de notificaciones. No respondas a este mensaje.
    </p>
  </div>
</body>
</html>
