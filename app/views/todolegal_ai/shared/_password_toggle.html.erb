<%# Password visibility toggle button — powered by password_toggle_controller.js (Stimulus).
    No locals. Must be rendered inside a <div data-controller="password-toggle"> wrapper.
    The sibling input must have data-password-toggle-target="input".
    Each wrapper div creates an independent Stimulus instance, so multiple toggles
    on the same page work correctly with no IDs or global JS. %>
<button
  type="button"
  data-action="click->password-toggle#toggle"
  aria-label="Mostrar/ocultar contraseña"
  class="absolute inset-y-0 right-3 flex items-center text-slate-400 hover:text-slate-600 transition"
>
  <svg data-password-toggle-target="eye" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
  <svg data-password-toggle-target="eyeOff" class="hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.733 5.076a10.744 10.744 0 0 1 11.205 6.575 1 1 0 0 1 0 .696 10.747 10.747 0 0 1-1.444 2.49"/><path d="M14.084 14.158a3 3 0 0 1-4.242-4.242"/><path d="M17.479 17.499a10.75 10.75 0 0 1-15.417-5.151 1 1 0 0 1 0-.696 10.75 10.75 0 0 1 4.446-5.143"/><path d="m2 2 20 20"/></svg>
</button>
